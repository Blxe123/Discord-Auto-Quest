# คัดลอกเป็น .env (local) หรือใส่ใน Railway → Variables

# ── จำเป็น ───────────────────────────────────────────────
DISCORD_BOT_TOKEN=bot_token_จาก_developer_portal
OWNER_ID=discord_user_id_ของคุณ
# Postgres — Railway ใส่ DATABASE_URL ให้อัตโนมัติเมื่อ add Postgres plugin
DATABASE_URL=postgresql://postgres:questbot@localhost:5432/questbot
# Fernet key เข้ารหัส token — สร้างครั้งเดียว แล้ว "ห้ามเปลี่ยน" (ไม่งั้น decrypt ของเดิมไม่ได้)
#   สร้าง: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── optional ─────────────────────────────────────────────
GUILD_ID=           # server id — ใส่แล้ว slash command โผล่ทันที
FARM_INTERVAL_MIN=10  # บอทวน farm ทุกกี่นาที (default 10)
ENABLE_PRESENCE=1   # 1=โชว์เควสบนโปรไฟล์ user ระหว่าง farm (self-bot, เสี่ยงแบนขึ้น) · 0=ปิด
